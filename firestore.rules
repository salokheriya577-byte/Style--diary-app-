rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- Entity Validators ---
    function isValidUser(data) {
      return data.email is string || data.preferences is list;
    }

    function isValidItem(data, userId) {
      return data.name is string && 
             data.category is string && 
             data.imageUrl is string && 
             data.weatherTags is list &&
             data.userId == userId;
    }

    function isValidOutfit(data, userId) {
      return data.name is string && 
             data.itemIds is list && 
             data.userId == userId;
    }

    function isValidLog(data, userId) {
      return data.date is string && 
             data.outfitId is string && 
             data.userId == userId;
    }

    // --- Match Rules ---

    // USERS
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());
      allow delete: if isOwner(userId);

      // ITEMS
      match /items/{itemId} {
        allow read: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(itemId) && isValidItem(incoming(), userId);
        allow update: if isOwner(userId) && isValidId(itemId);
        allow delete: if isOwner(userId);
      }

      // OUTFITS
      match /outfits/{outfitId} {
        allow read: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(outfitId) && isValidOutfit(incoming(), userId);
        allow update: if isOwner(userId) && isValidId(outfitId);
        allow delete: if isOwner(userId);
      }

      // LOGS
      match /logs/{logId} {
        allow read: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(logId) && isValidLog(incoming(), userId);
        allow update: if isOwner(userId) && isValidId(logId);
        allow delete: if isOwner(userId);
      }
    }
  }
}
